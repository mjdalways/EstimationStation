<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#343a40" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="EstStation" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <title>@ViewData["Title"] - EstimationStation</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("HeadStyles", required: false)
</head>
<body data-theme="classic" id="appBody">
    <nav class="navbar navbar-expand-lg" id="mainNavbar">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🃏 EstimationStation</a>

            <!-- Bootstrap hamburger toggler -->
            <button class="navbar-toggler ms-auto me-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavContent" aria-controls="mainNavContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon-custom">☰</span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavContent">
                @RenderSection("NavbarExtra", required: false)
                <div class="d-flex align-items-center gap-2 ms-auto py-1">
                    <select id="themeSelect" class="form-select form-select-sm nav-theme-select" onchange="onThemeChange(this.value)" title="Change theme">
                        <optgroup label="Classic">
                            <option value="classic">Classic</option>
                            <option value="dark">Dark</option>
                            <option value="forest">Forest</option>
                            <option value="ocean">Ocean</option>
                            <option value="retro">Retro</option>
                        </optgroup>
                        <optgroup label="Fun">
                            <option value="floral">🌸 Floral</option>
                            <option value="eighties">📼 1980s</option>
                            <option value="redyellow">🔴 Red &amp; Yellow</option>
                            <option value="blueyellow">🔵 Blue &amp; Yellow</option>
                            <option value="myspace">💻 MySpace</option>
                            <option value="geocities">🌐 GeoCities</option>
                        </optgroup>
                        <optgroup label="Custom" id="customThemeOptgroup">
                            <option value="custom_new">➕ Create Custom…</option>
                        </optgroup>
                    </select>
                    <button class="btn btn-sm btn-outline-light" data-bs-toggle="modal" data-bs-target="#recentChangesModal" title="Recent changes">📝</button>
                    <button class="btn btn-sm btn-outline-light" onclick="openCelebrationSettings()" title="Celebration settings">🎉</button>
                    <button class="btn btn-sm btn-outline-light d-none" id="editCustomThemeBtn" onclick="editCurrentCustomTheme()" title="Edit Custom Theme">✏️</button>
                    <button class="btn btn-sm btn-outline-light d-none" id="installAppBtn" onclick="installApp()" title="Add to Home Screen">📲 Install</button>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-0">
        @RenderBody()
    </div>

    <!-- Custom Theme Builder Modal -->
    <div class="modal fade" id="customThemeModal" tabindex="-1" aria-labelledby="customThemeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="customThemeModalLabel">🎨 Build Your Custom Theme</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="cancelCustomTheme()"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <input type="hidden" id="ct-theme-id" />
                        <div class="col-12 border-bottom pb-3 mb-2">
                            <div class="d-flex justify-content-between align-items-end mb-2">
                                <label class="form-label mb-0" for="ct-theme-name"><strong>Theme Name</strong></label>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportCustomTheme()" title="Save JSON to file">⬇️ Export</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="importCustomTheme()" title="Load JSON from file">⬆️ Import</button>
                                </div>
                            </div>
                            <input type="text" class="form-control" id="ct-theme-name" placeholder="My Awesome Theme" />
                            <div class="row g-2 mt-2">
                                <div class="col-8">
                                    <label class="form-label mb-1" for="ct-base-theme">Start from existing theme</label>
                                    <select id="ct-base-theme" class="form-select form-select-sm"></select>
                                </div>
                                <div class="col-4 d-flex align-items-end">
                                    <button type="button" class="btn btn-sm btn-outline-primary w-100" onclick="loadThemePresetForCustomization()">Load</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-bg-primary">Page Background</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-bg-primary" value="#f8f9fa" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-bg-secondary">Panel Background</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-bg-secondary" value="#ffffff" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-text-primary">Text Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-text-primary" value="#212529" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-accent">Accent / Button Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-accent" value="#0d6efd" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-navbar-bg">Navbar Background</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-navbar-bg" value="#343a40" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-navbar-text">Navbar Text</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-navbar-text" value="#ffffff" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-card-selected">Selected Card Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-card-selected" value="#0d6efd" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-card-selected-text">Selected Card Text</label>
                            <input type="color" class="form-control form-control-color w-100" id="ct-card-selected-text" value="#ffffff" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label" for="ct-font-family">Font</label>
                            <select class="form-select" id="ct-font-family" onchange="updateCustomFontPreview(this.value)">
                                <optgroup label="System & Defaults">
                                    <option value="system-ui, sans-serif">System Default</option>
                                    <option value="'Segoe UI', Arial, sans-serif">Segoe UI</option>
                                    <option value="'Georgia', serif">Georgia (Serif)</option>
                                    <option value="'Courier New', monospace">Courier (Mono)</option>
                                    <option value="'Comic Sans MS', cursive">Comic Sans</option>
                                    <option value="'Impact', sans-serif">Impact</option>
                                    <option value="'Arial Black', sans-serif">Arial Black</option>
                                </optgroup>
                                <optgroup label="Standard & Clean">
                                    <option value="'Roboto', sans-serif">Roboto</option>
                                    <option value="'Open Sans', sans-serif">Open Sans</option>
                                    <option value="'Lato', sans-serif">Lato</option>
                                    <option value="'Montserrat', sans-serif">Montserrat</option>
                                    <option value="'Poppins', sans-serif">Poppins</option>
                                    <option value="'Oswald', sans-serif">Oswald</option>
                                </optgroup>
                                <optgroup label="Elegant & Serif">
                                    <option value="'Playfair Display', serif">Playfair Display</option>
                                    <option value="'Merriweather', serif">Merriweather</option>
                                    <option value="'Cinzel', serif">Cinzel</option>
                                    <option value="'Lora', serif">Lora</option>
                                </optgroup>
                                <optgroup label="Tech, Robot & Pixel">
                                    <option value="'Orbitron', sans-serif">Orbitron</option>
                                    <option value="'Share Tech Mono', monospace">Share Tech Mono</option>
                                    <option value="'Audiowide', sans-serif">Audiowide</option>
                                    <option value="'Roboto Mono', monospace">Roboto Mono</option>
                                    <option value="'VT323', monospace">VT323 (Terminal)</option>
                                    <option value="'Press Start 2P', system-ui">Press Start 2P (8-bit)</option>
                                    <option value="'Silkscreen', cursive">Silkscreen</option>
                                </optgroup>
                                <optgroup label="Playful & Casual">
                                    <option value="'Comic Neue', cursive">Comic Neue</option>
                                    <option value="'Fredoka', sans-serif">Fredoka</option>
                                    <option value="'Chewy', cursive">Chewy</option>
                                    <option value="'Luckiest Guy', cursive">Luckiest Guy</option>
                                    <option value="'Bangers', cursive">Bangers</option>
                                    <option value="'Lobster', cursive">Lobster</option>
                                    <option value="'Rubik Bubbles', cursive">Rubik Bubbles</option>
                                </optgroup>
                                <optgroup label="Handwriting & Script">
                                    <option value="'Caveat', cursive">Caveat</option>
                                    <option value="'Shadows Into Light', cursive">Shadows Into Light</option>
                                    <option value="'Indie Flower', cursive">Indie Flower</option>
                                    <option value="'Permanent Marker', cursive">Permanent Marker</option>
                                    <option value="'Amatic SC', cursive">Amatic SC</option>
                                    <option value="'Pacifico', cursive">Pacifico</option>
                                    <option value="'Great Vibes', cursive">Great Vibes</option>
                                </optgroup>
                                <optgroup label="Colors & Effects">
                                    <option value="'Nabla', system-ui">Nabla (Isometric Color)</option>
                                    <option value="'Bungee Spice', system-ui">Bungee Spice (Color)</option>
                                    <option value="'Honk', system-ui">Honk!</option>
                                    <option value="'Noto Color Emoji', sans-serif">Noto Color Emoji</option>
                                    <option value="'Bungee Tint', system-ui">Bungee Tint</option>
                                    <option value="'Foldit', system-ui">Foldit</option>
                                    <option value="'Rocher', system-ui">Rocher</option>
                                    <option value="'Danfo', system-ui">Danfo</option>
                                    <option value="'Sixtyfour', system-ui">Sixtyfour</option>
                                    <option value="'Tourney', system-ui">Tourney</option>
                                </optgroup>
                                <optgroup label="Holiday: Valentine's Day">
                                    <option value="'Lovers Quarrel', cursive">Lovers Quarrel</option>
                                    <option value="'Parisienne', cursive">Parisienne</option>
                                    <option value="'Dancing Script', cursive">Dancing Script</option>
                                </optgroup>
                                <optgroup label="Holiday: Halloween">
                                    <option value="'Creepster', cursive">Creepster</option>
                                    <option value="'Nosifer', cursive">Nosifer</option>
                                    <option value="'Butcherman', cursive">Butcherman</option>
                                    <option value="'Eater', cursive">Eater</option>
                                </optgroup>
                                <optgroup label="Holiday: Christmas">
                                    <option value="'Mountains of Christmas', cursive">Mountains of Christmas</option>
                                    <option value="'Emilys Candy', cursive">Emilys Candy</option>
                                    <option value="'Berkshire Swash', cursive">Berkshire Swash</option>
                                </optgroup>
                            </select>
                            <div class="form-text mt-2">Font preview</div>
                            <div id="ct-font-preview" class="border rounded p-2" style="min-height: 48px;">
                                The quick brown fox jumps over 13 lazy dogs. 🎨
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="ct-border-radius">
                                Corner Roundness: <strong><span id="ct-radius-label">8</span>px</strong>
                            </label>
                            <input type="range" class="form-range" id="ct-border-radius" min="0" max="24" value="8"
                                   oninput="document.getElementById('ct-radius-label').textContent=this.value" />
                        </div>
                        <div class="col-12 border-top pt-3 mt-1">
                            <h6 class="mb-1">🎊 Celebration Colors</h6>
                            <label class="form-label small" for="ct-confetti-colors">Confetti colors for this theme (hex, comma-separated)</label>
                            <input type="text" class="form-control form-control-sm" id="ct-confetti-colors"
                                   placeholder="#0d6efd,#198754,#ffc107,#dc3545,#ffffff" />
                            <div class="form-text">Used when "Use theme colors" is enabled in Celebration Settings.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger me-auto d-none" id="ct-delete-btn" onclick="deleteCustomTheme()">🗑️ Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="cancelCustomTheme()">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveCustomTheme()">💾 Save Theme</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Celebration Settings Modal -->
    <div class="modal fade" id="celebrationSettingsModal" tabindex="-1" aria-labelledby="celebrationSettingsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="celebrationSettingsModalLabel">🎉 Celebration Settings</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Enable / Disable toggles -->
                    <div class="d-flex gap-4 mb-3 flex-wrap">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="cel-enable-confetti" />
                            <label class="form-check-label fw-semibold" for="cel-enable-confetti">🎊 Confetti</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="cel-enable-fireworks" />
                            <label class="form-check-label fw-semibold" for="cel-enable-fireworks">🎆 Fireworks</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="cel-enable-balloons" />
                            <label class="form-check-label fw-semibold" for="cel-enable-balloons">🎈 Balloons</label>
                        </div>
                    </div>

                    <!-- ── Confetti ── -->
                    <h6 class="text-muted border-bottom pb-1 mb-2">🎊 Confetti</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small mb-1" for="cel-confetti-type">Particle type</label>
                            <select id="cel-confetti-type" class="form-select form-select-sm"
                                    onchange="_updateEmojiVisibility(this.value==='emoji')">
                                <option value="default">Default</option>
                                <option value="stars">⭐ Stars</option>
                                <option value="hearts">❤️ Hearts</option>
                                <option value="snow">❄️ Snow</option>
                                <option value="emoji">😀 Custom Emoji</option>
                                <option value="christmasHoliday">🎄 Christmas</option>
                                <option value="halloweenHoliday">🎃 Halloween</option>
                                <option value="valentineHoliday">💕 Valentine's</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1" for="cel-confetti-duration">Duration</label>
                            <div class="input-group input-group-sm">
                                <input type="number" id="cel-confetti-duration" class="form-control" min="1000" max="15000" step="500" value="4000" />
                                <span class="input-group-text">ms</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Particles: <span id="cel-particles-val">150</span></label>
                            <input type="range" id="cel-confetti-particles" class="form-range" min="20" max="500" step="10" value="150"
                                   oninput="document.getElementById('cel-particles-val').textContent=this.value" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Spread: <span id="cel-spread-val">70</span>°</label>
                            <input type="range" id="cel-confetti-spread" class="form-range" min="20" max="180" step="5" value="70"
                                   oninput="document.getElementById('cel-spread-val').textContent=this.value+'°'" />
                        </div>
                        <div class="col-md-4 d-flex align-items-center">
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="cel-confetti-use-theme"
                                       onchange="_updateCustomColorsVisibility(!this.checked)" />
                                <label class="form-check-label small" for="cel-confetti-use-theme">Use theme colors</label>
                            </div>
                        </div>
                        <div id="cel-custom-colors-group" class="col-12" style="display:none;">
                            <label class="form-label small mb-1" for="cel-confetti-colors">Custom colors (hex, comma-separated)</label>
                            <input type="text" id="cel-confetti-colors" class="form-control form-control-sm"
                                   placeholder="#ff0000,#00cc00,#0000ff,#ffcc00,#ff00ff" />
                        </div>
                        <div id="cel-emoji-group" class="col-12" style="display:none;">
                            <label class="form-label small mb-1" for="cel-confetti-emojis">Custom emojis (comma-separated)</label>
                            <input type="text" id="cel-confetti-emojis" class="form-control form-control-sm"
                                   placeholder="🎉,🎊,✨,🎈" />
                        </div>
                    </div>

                    <!-- ── Fireworks ── -->
                    <h6 class="text-muted border-bottom pb-1 mb-2">🎆 Fireworks</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small mb-1" for="cel-fireworks-duration">Duration</label>
                            <div class="input-group input-group-sm">
                                <input type="number" id="cel-fireworks-duration" class="form-control" min="1000" max="30000" step="1000" value="5000" />
                                <span class="input-group-text">ms</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Intensity: <span id="cel-intensity-val">30</span></label>
                            <input type="range" id="cel-fireworks-intensity" class="form-range" min="5" max="100" step="5" value="30"
                                   oninput="document.getElementById('cel-intensity-val').textContent=this.value" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Particles: <span id="cel-fw-particles-val">50</span></label>
                            <input type="range" id="cel-fireworks-particles" class="form-range" min="10" max="200" step="10" value="50"
                                   oninput="document.getElementById('cel-fw-particles-val').textContent=this.value" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Explosion spread: <span id="cel-explosion-val">5</span></label>
                            <input type="range" id="cel-fireworks-explosion" class="form-range" min="1" max="20" step="1" value="5"
                                   oninput="document.getElementById('cel-explosion-val').textContent=this.value" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Launch point: <span id="cel-rockets-val">50%</span></label>
                            <input type="range" id="cel-fireworks-rockets" class="form-range" min="0" max="100" step="5" value="50"
                                   oninput="document.getElementById('cel-rockets-val').textContent=this.value+'%'" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Color hue range</label>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="number" id="cel-fireworks-hue-min" class="form-control form-control-sm" min="0" max="360" value="0" style="width:70px" />
                                <span class="small">–</span>
                                <input type="number" id="cel-fireworks-hue-max" class="form-control form-control-sm" min="0" max="360" value="360" style="width:70px" />
                            </div>
                        </div>
                    </div>

                    <!-- ── Balloons ── -->
                    <h6 class="text-muted border-bottom pb-1 mb-2">🎈 Balloons</h6>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label small mb-1">Count: <span id="cel-balloon-count-val">10</span></label>
                            <input type="range" id="cel-balloon-count" class="form-range" min="1" max="30" step="1" value="10"
                                   oninput="document.getElementById('cel-balloon-count-val').textContent=this.value" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small mb-1" for="cel-balloon-duration">Duration</label>
                            <div class="input-group input-group-sm">
                                <input type="number" id="cel-balloon-duration" class="form-control" min="2000" max="20000" step="1000" value="6000" />
                                <span class="input-group-text">ms</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary me-auto" onclick="resetCelebrationSettings()">↩ Reset defaults</button>
                    <button type="button" class="btn btn-outline-success" onclick="testCelebration()">🎉 Test</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveCelebrationSettingsFromForm()">💾 Save</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="recentChangesModal" tabindex="-1" aria-labelledby="recentChangesModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="recentChangesModalLabel">Recent changes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2"><strong>3/4/2026</strong></p>
                    <p class="mb-2"><strong>@DateTime.Now.ToString("M/d/yyyy")</strong></p>
                    <ul class="mb-2">
                        <li>🎉 Consensus now triggers a full celebration — confetti, fireworks, and balloons!</li>
                        <li>All celebration effects are independently toggleable and fully configurable via the 🎉 button in the toolbar.</li>
                        <li>Confetti supports theme-matched colors, holiday modes (Christmas, Halloween, Valentine's), emoji, stars, snow, and custom colors.</li>
                        <li>Fireworks intensity, particles, explosion, hue range, launch point, and duration are all adjustable.</li>
                        <li>Balloons are rendered in pure CSS — no images — with count and duration controls.</li>
                        <li>Custom themes can now specify their own confetti colors in the theme builder.</li>
                        <li>Fixed a too-many-redirects issue for users on shared hosting (IONOS).</li>
                    </ul>
                    <p class="mb-2"><strong>3/4/2026</strong></p>
                    <ul class="mb-0">
                        <li>Creating a new custom theme now starts with your current theme automatically.</li>
                        <li>Recent updates now appear on normal refresh, without needing Ctrl+F5.</li>
                        <li>Improved theme picker reliability so your saved theme shows correctly on page load.</li>
                        <li>Fixed startup issue where the theme selector could appear blank on first load.</li>
                        <li>Fixed loading existing themes so the matching font now appears correctly in the customizer.</li>
                        <li>Fixed an issue where creating a custom theme could stop opening the customizer.</li>
                        <li>Share room invite links more easily.</li>
                        <li>People joining from a link are guided to enter their name first.</li>
                        <li>You can now create, edit, save, import, and export custom themes.</li>
                        <li>The theme picker is easier to use with your saved themes listed.</li>
                        <li>Custom theme setup now includes live font preview and more font choices.</li>
                        <li>You can start a custom theme from any existing theme.</li>
                        <li>Added a quick Recent Changes button in the top bar.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Celebration libraries (canvas-confetti + fireworks-js) loaded from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1/dist/confetti.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fireworks-js@2/dist/index.umd.js"></script>
    <script src="~/js/celebration.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Register service worker for PWA
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(err => console.warn('SW registration failed:', err));
        }
    </script>
</body>
</html>


