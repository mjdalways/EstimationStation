<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#343a40" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="EstStation" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <title>@ViewData["Title"] - EstimationStation</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("HeadStyles", required: false)
</head>
<body data-theme="classic" id="appBody">
    <nav class="navbar navbar-expand-lg" id="mainNavbar">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🃏 EstimationStation</a>

            <!-- Bootstrap hamburger toggler -->
            <button class="navbar-toggler ms-auto me-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavContent" aria-controls="mainNavContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon-custom">☰</span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavContent">
                @RenderSection("NavbarExtra", required: false)
                <div class="d-flex align-items-center gap-2 ms-auto py-1">
                    <select id="themeSelect" class="form-select form-select-sm nav-theme-select" onchange="onThemeChange(this.value)" title="Change theme">
                        <optgroup label="Classic">
                            <option value="classic">Classic</option>
                            <option value="dark">Dark</option>
                            <option value="forest">Forest</option>
                            <option value="ocean">Ocean</option>
                            <option value="retro">Retro</option>
                        </optgroup>
                        <optgroup label="Fun">
                            <option value="floral">🌸 Floral</option>
                            <option value="eighties">📼 1980s</option>
                            <option value="redyellow">🔴 Red &amp; Yellow</option>
                            <option value="blueyellow">🔵 Blue &amp; Yellow</option>
                            <option value="myspace">💻 MySpace</option>
                            <option value="geocities">🌐 GeoCities</option>
                        </optgroup>
                        <optgroup label="Custom" id="customThemeOptgroup">
                            <option value="custom_new">➕ Create Custom…</option>
                        </optgroup>
                    </select>
                    <button class="btn btn-sm btn-outline-light" onclick="openSettingsModal()" title="Settings">⚙️</button>
                    <button class="btn btn-sm btn-outline-light d-none" id="installAppBtn" onclick="installApp()" title="Add to Home Screen">📲 Install</button>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-0">
        @RenderBody()
    </div>

    <!-- ============================================================
         Unified Settings Modal
         Tabs: 🎨 Theme | 🎉 Celebration | 👤 Profile | ℹ️ About
         ============================================================ -->
    <div class="modal fade" id="settingsModal" tabindex="-1" aria-labelledby="settingsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable settings-modal-dialog">
            <div class="modal-content h-100">

                <!-- Header -->
                <div class="modal-header py-2 border-bottom">
                    <h5 class="modal-title fs-6 fw-bold" id="settingsModalLabel">⚙️ Settings</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <!-- Tab nav -->
                <ul class="nav nav-tabs settings-tabs px-3 pt-2 border-bottom-0" id="settingsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active settings-tab-btn" id="tab-theme-btn" data-bs-toggle="tab" data-bs-target="#tab-theme" type="button" role="tab">🎨 <span class="tab-label">Theme</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link settings-tab-btn" id="tab-celebration-btn" data-bs-toggle="tab" data-bs-target="#tab-celebration" type="button" role="tab">🎉 <span class="tab-label">Celebration</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link settings-tab-btn" id="tab-profile-btn" data-bs-toggle="tab" data-bs-target="#tab-profile" type="button" role="tab">👤 <span class="tab-label">Profile</span></button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link settings-tab-btn" id="tab-about-btn" data-bs-toggle="tab" data-bs-target="#tab-about" type="button" role="tab">ℹ️ <span class="tab-label">About</span></button>
                    </li>
                </ul>

                <!-- Tab content -->
                <div class="tab-content flex-fill overflow-hidden" id="settingsTabContent">

                    <!-- ══════════════════════════════════════════
                         TAB: 🎨 Theme
                         ══════════════════════════════════════════ -->
                    <div class="tab-pane fade show active h-100" id="tab-theme" role="tabpanel">
                        <div class="d-flex h-100 overflow-hidden">

                            <!-- Left: controls -->
                            <div class="flex-fill overflow-auto p-3" style="min-width:0;">
                                <input type="hidden" id="ct-theme-id" />

                                <!-- Theme name + base + import/export -->
                                <div class="d-flex gap-2 mb-3 flex-wrap align-items-end">
                                    <div class="flex-fill" style="min-width:140px;">
                                        <label class="ct-field-label" for="ct-theme-name">Theme Name</label>
                                        <input type="text" class="form-control form-control-sm" id="ct-theme-name" placeholder="My Awesome Theme" oninput="updateThemePreview()" />
                                    </div>
                                    <div style="min-width:130px;">
                                        <label class="ct-field-label" for="ct-base-theme">Start from</label>
                                        <div class="input-group input-group-sm">
                                            <select id="ct-base-theme" class="form-select form-select-sm"></select>
                                            <button type="button" class="btn btn-outline-secondary" onclick="loadThemePresetForCustomization()" title="Load">↺</button>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="exportCustomTheme()" title="Export JSON">⬇️</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="importCustomTheme()" title="Import JSON">⬆️</button>
                                        <button type="button" class="btn btn-sm btn-danger d-none" id="ct-delete-btn" onclick="deleteCustomTheme()" title="Delete theme">🗑️</button>
                                    </div>
                                </div>

                                <!-- Page & Layout -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-page', this)">
                                        <span>🖥️ Page &amp; Layout</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-page" class="ct-section-body">
                                        <div class="ct-swatch-row">
                                            <div class="ct-swatch-item"><input type="color" id="ct-bg-primary" value="#f8f9fa" oninput="updateThemePreview()" /><span>Page BG</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-bg-secondary" value="#ffffff" oninput="updateThemePreview()" /><span>Panel BG</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-panel-bg" value="#ffffff" oninput="updateThemePreview()" /><span>Side Panel</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-panel-border" value="#dee2e6" oninput="updateThemePreview()" /><span>Panel Border</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-stats-bg" value="#e7f1ff" oninput="updateThemePreview()" /><span>Stats Bar</span></div>
                                        </div>
                                        <div class="row g-2 mt-2">
                                            <div class="col-12">
                                                <label class="ct-field-label">Corner Roundness: <strong><span id="ct-radius-label">8</span>px</strong></label>
                                                <input type="range" class="form-range" id="ct-border-radius" min="0" max="24" value="8" oninput="document.getElementById('ct-radius-label').textContent=this.value; updateThemePreview()" />
                                            </div>
                                            <div class="col-12">
                                                <label class="ct-field-label" for="ct-shadow">Box Shadow</label>
                                                <input type="text" class="form-control form-control-sm" id="ct-shadow" value="0 2px 8px rgba(0,0,0,0.1)" oninput="updateThemePreview()" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Typography -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-type', this)">
                                        <span>✍️ Typography</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-type" class="ct-section-body">
                                        <div class="ct-swatch-row mb-2">
                                            <div class="ct-swatch-item"><input type="color" id="ct-text-primary" value="#212529" oninput="updateThemePreview()" /><span>Primary</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-text-secondary" value="#6c757d" oninput="updateThemePreview()" /><span>Secondary</span></div>
                                        </div>
                                        <div class="row g-2">
                                            <div class="col-12">
                                                <label class="ct-field-label" for="ct-font-family">Body Font</label>
                                                <select class="form-select form-select-sm" id="ct-font-family" onchange="updateCustomFontPreview(this.value); updateThemePreview()">
                                                    <optgroup label="System &amp; Defaults">
                                                        <option value="system-ui, sans-serif">System Default</option>
                                                        <option value="'Segoe UI', Arial, sans-serif">Segoe UI</option>
                                                        <option value="'Georgia', serif">Georgia</option>
                                                        <option value="'Courier New', monospace">Courier</option>
                                                        <option value="'Comic Sans MS', cursive">Comic Sans</option>
                                                        <option value="'Impact', sans-serif">Impact</option>
                                                        <option value="'Arial Black', sans-serif">Arial Black</option>
                                                    </optgroup>
                                                    <optgroup label="Standard &amp; Clean">
                                                        <option value="'Roboto', sans-serif">Roboto</option>
                                                        <option value="'Open Sans', sans-serif">Open Sans</option>
                                                        <option value="'Lato', sans-serif">Lato</option>
                                                        <option value="'Montserrat', sans-serif">Montserrat</option>
                                                        <option value="'Poppins', sans-serif">Poppins</option>
                                                        <option value="'Oswald', sans-serif">Oswald</option>
                                                    </optgroup>
                                                    <optgroup label="Elegant &amp; Serif">
                                                        <option value="'Playfair Display', serif">Playfair Display</option>
                                                        <option value="'Merriweather', serif">Merriweather</option>
                                                        <option value="'Cinzel', serif">Cinzel</option>
                                                        <option value="'Lora', serif">Lora</option>
                                                    </optgroup>
                                                    <optgroup label="Tech &amp; Pixel">
                                                        <option value="'Orbitron', sans-serif">Orbitron</option>
                                                        <option value="'Share Tech Mono', monospace">Share Tech Mono</option>
                                                        <option value="'Audiowide', sans-serif">Audiowide</option>
                                                        <option value="'Roboto Mono', monospace">Roboto Mono</option>
                                                        <option value="'VT323', monospace">VT323 (Terminal)</option>
                                                        <option value="'Press Start 2P', system-ui">Press Start 2P</option>
                                                        <option value="'Silkscreen', cursive">Silkscreen</option>
                                                    </optgroup>
                                                    <optgroup label="Playful">
                                                        <option value="'Comic Neue', cursive">Comic Neue</option>
                                                        <option value="'Fredoka', sans-serif">Fredoka</option>
                                                        <option value="'Chewy', cursive">Chewy</option>
                                                        <option value="'Luckiest Guy', cursive">Luckiest Guy</option>
                                                        <option value="'Bangers', cursive">Bangers</option>
                                                        <option value="'Lobster', cursive">Lobster</option>
                                                        <option value="'Rubik Bubbles', cursive">Rubik Bubbles</option>
                                                    </optgroup>
                                                    <optgroup label="Handwriting">
                                                        <option value="'Caveat', cursive">Caveat</option>
                                                        <option value="'Shadows Into Light', cursive">Shadows Into Light</option>
                                                        <option value="'Indie Flower', cursive">Indie Flower</option>
                                                        <option value="'Permanent Marker', cursive">Permanent Marker</option>
                                                        <option value="'Amatic SC', cursive">Amatic SC</option>
                                                        <option value="'Pacifico', cursive">Pacifico</option>
                                                        <option value="'Great Vibes', cursive">Great Vibes</option>
                                                    </optgroup>
                                                    <optgroup label="Colors &amp; Effects">
                                                        <option value="'Nabla', system-ui">Nabla</option>
                                                        <option value="'Bungee Spice', system-ui">Bungee Spice</option>
                                                        <option value="'Honk', system-ui">Honk!</option>
                                                        <option value="'Noto Color Emoji', sans-serif">Noto Color Emoji</option>
                                                        <option value="'Bungee Tint', system-ui">Bungee Tint</option>
                                                        <option value="'Foldit', system-ui">Foldit</option>
                                                        <option value="'Rocher', system-ui">Rocher</option>
                                                        <option value="'Danfo', system-ui">Danfo</option>
                                                        <option value="'Sixtyfour', system-ui">Sixtyfour</option>
                                                        <option value="'Tourney', system-ui">Tourney</option>
                                                    </optgroup>
                                                    <optgroup label="Holiday: Valentine's">
                                                        <option value="'Lovers Quarrel', cursive">Lovers Quarrel</option>
                                                        <option value="'Parisienne', cursive">Parisienne</option>
                                                        <option value="'Dancing Script', cursive">Dancing Script</option>
                                                    </optgroup>
                                                    <optgroup label="Holiday: Halloween">
                                                        <option value="'Creepster', cursive">Creepster</option>
                                                        <option value="'Nosifer', cursive">Nosifer</option>
                                                        <option value="'Butcherman', cursive">Butcherman</option>
                                                        <option value="'Eater', cursive">Eater</option>
                                                    </optgroup>
                                                    <optgroup label="Holiday: Christmas">
                                                        <option value="'Mountains of Christmas', cursive">Mountains of Christmas</option>
                                                        <option value="'Emilys Candy', cursive">Emilys Candy</option>
                                                        <option value="'Berkshire Swash', cursive">Berkshire Swash</option>
                                                    </optgroup>
                                                </select>
                                            </div>
                                            <div class="col-12">
                                                <label class="ct-field-label" for="ct-heading-font">Heading Font (CSS value)</label>
                                                <input type="text" class="form-control form-control-sm" id="ct-heading-font" value="'Segoe UI', system-ui, sans-serif" oninput="updateThemePreview()" />
                                            </div>
                                            <div class="col-12">
                                                <div id="ct-font-preview" class="border rounded p-2 mt-1" style="min-height:36px;font-size:0.85rem;">
                                                    The quick brown fox jumps over 13 lazy dogs. 🎨
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Navbar -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-nav', this)">
                                        <span>🔝 Navbar</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-nav" class="ct-section-body">
                                        <div class="ct-swatch-row">
                                            <div class="ct-swatch-item"><input type="color" id="ct-navbar-bg" value="#343a40" oninput="updateThemePreview()" /><span>Background</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-navbar-text" value="#ffffff" oninput="updateThemePreview()" /><span>Text</span></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Accent & Buttons -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-accent', this)">
                                        <span>🎨 Accent &amp; Buttons</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-accent" class="ct-section-body">
                                        <div class="ct-swatch-row">
                                            <div class="ct-swatch-item"><input type="color" id="ct-accent" value="#0d6efd" oninput="updateThemePreview()" /><span>Accent</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-accent-hover" value="#0b5ed7" oninput="updateThemePreview()" /><span>Hover</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-btn-primary" value="#0d6efd" oninput="updateThemePreview()" /><span>Primary Btn</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-btn-reveal" value="#198754" oninput="updateThemePreview()" /><span>Reveal Btn</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-btn-reset" value="#ffc107" oninput="updateThemePreview()" /><span>Reset Btn</span></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cards -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-cards', this)">
                                        <span>🃏 Cards</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-cards" class="ct-section-body">
                                        <div class="ct-swatch-row mb-2">
                                            <div class="ct-swatch-item"><input type="color" id="ct-card-bg" value="#ffffff" oninput="updateThemePreview()" /><span>Card BG</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-card-hover" value="#e7f1ff" oninput="updateThemePreview()" /><span>Hover BG</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-card-selected" value="#0d6efd" oninput="updateThemePreview()" /><span>Selected</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-card-selected-text" value="#ffffff" oninput="updateThemePreview()" /><span>Sel. Text</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-card-border" value="#dee2e6" oninput="updateThemePreview()" /><span>Border</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-card-voted" value="#198754" oninput="updateThemePreview()" /><span>Voted</span></div>
                                        </div>
                                        <div class="row g-2">
                                            <div class="col-8">
                                                <label class="ct-field-label">Border Width: <strong><span id="ct-border-width-label">1.5</span>px</strong></label>
                                                <input type="range" class="form-range" id="ct-card-border-width" min="0" max="8" step="0.5" value="1.5" oninput="document.getElementById('ct-border-width-label').textContent=this.value; updateThemePreview()" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Stories & Chat -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-stories', this)">
                                        <span>📋 Stories &amp; Chat</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-stories" class="ct-section-body">
                                        <div class="ct-swatch-row">
                                            <div class="ct-swatch-item"><input type="color" id="ct-story-active" value="#cfe2ff" oninput="updateThemePreview()" /><span>Active Story</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-story-completed" value="#d1e7dd" oninput="updateThemePreview()" /><span>Completed</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-chat-bg" value="#f8f9fa" oninput="updateThemePreview()" /><span>Chat BG</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-chat-bubble" value="#e9ecef" oninput="updateThemePreview()" /><span>Chat Bubble</span></div>
                                            <div class="ct-swatch-item"><input type="color" id="ct-timer-color" value="#dc3545" oninput="updateThemePreview()" /><span>Timer</span></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Celebration colors -->
                                <div class="mb-2">
                                    <div class="ct-section-header" onclick="ctToggleSection('sec-ct-celebration', this)">
                                        <span>🎊 Celebration Colors</span><em class="ct-section-chevron">▾</em>
                                    </div>
                                    <div id="sec-ct-celebration" class="ct-section-body">
                                        <p class="small text-muted mb-2">Up to 6 confetti colors for this theme. Used when "Use theme colors" is on.</p>
                                        <div class="ct-swatch-row" id="ct-confetti-swatches">
                                            <div class="ct-swatch-item"><input type="color" class="ct-confetti-swatch" value="#0d6efd" oninput="syncConfettiSwatchesToField()" /><span>1</span></div>
                                            <div class="ct-swatch-item"><input type="color" class="ct-confetti-swatch" value="#198754" oninput="syncConfettiSwatchesToField()" /><span>2</span></div>
                                            <div class="ct-swatch-item"><input type="color" class="ct-confetti-swatch" value="#ffc107" oninput="syncConfettiSwatchesToField()" /><span>3</span></div>
                                            <div class="ct-swatch-item"><input type="color" class="ct-confetti-swatch" value="#dc3545" oninput="syncConfettiSwatchesToField()" /><span>4</span></div>
                                            <div class="ct-swatch-item"><input type="color" class="ct-confetti-swatch" value="#6f42c1" oninput="syncConfettiSwatchesToField()" /><span>5</span></div>
                                            <div class="ct-swatch-item"><input type="color" class="ct-confetti-swatch" value="#ffffff" oninput="syncConfettiSwatchesToField()" /><span>6</span></div>
                                        </div>
                                        <input type="hidden" id="ct-confetti-colors" />
                                    </div>
                                </div>

                            </div><!-- end left controls -->

                            <!-- Right: live preview (desktop only) -->
                            <div class="border-start p-3 d-none d-lg-block" style="width:210px;flex-shrink:0;overflow-y:auto;">
                                <div class="fw-bold mb-2 small text-muted text-uppercase" style="letter-spacing:.05em;">Live Preview</div>
                                <div id="ct-live-preview">
                                    <div class="ct-preview-navbar" id="pv-navbar"><span>🃏</span><span id="pv-brand" style="font-size:0.75rem;font-weight:700;">EstStation</span></div>
                                    <div class="ct-preview-body" id="pv-body">
                                        <div class="d-flex flex-column gap-1">
                                            <div class="ct-preview-card" id="pv-card-normal">5</div>
                                            <div class="ct-preview-card" id="pv-card-selected">8</div>
                                        </div>
                                        <div class="ct-preview-participants">
                                            <div class="ct-preview-badge" id="pv-badge-default">Alice <span>?</span></div>
                                            <div class="ct-preview-badge" id="pv-badge-voted">Bob <span>✓</span></div>
                                            <div class="ct-preview-badge" id="pv-badge-me">You <span>8</span></div>
                                        </div>
                                    </div>
                                    <div class="px-2 pb-2">
                                        <span class="ct-preview-btn" id="pv-btn-reveal">Reveal</span>
                                        <span class="ct-preview-btn" id="pv-btn-reset">Reset</span>
                                    </div>
                                    <div class="ct-preview-chat" id="pv-chat">
                                        <span style="font-weight:700;font-size:0.68rem;" id="pv-chat-author">Alice:</span>
                                        <span class="ct-preview-chat" id="pv-chat-bubble" style="display:inline-block;margin:0;"> Ready!</span>
                                    </div>
                                    <div class="px-2 pb-2 mt-1">
                                        <div style="border-radius:4px;padding:3px 7px;font-size:0.68rem;font-weight:600;margin-bottom:3px;" id="pv-story-active">User story A</div>
                                        <div style="border-radius:4px;padding:3px 7px;font-size:0.68rem;font-weight:600;opacity:0.75;" id="pv-story-done">User story B ✓</div>
                                    </div>
                                </div>
                                <div class="mt-3 d-flex flex-column gap-2">
                                    <button type="button" class="btn btn-sm btn-danger d-none w-100" id="ct-delete-btn-preview" onclick="deleteCustomTheme()">🗑️ Delete Theme</button>
                                    <button type="button" class="btn btn-sm btn-primary w-100" onclick="saveCustomTheme()">💾 Save Theme</button>
                                </div>
                            </div><!-- end right preview -->

                        </div><!-- end d-flex theme tab -->

                        <!-- Mobile save/delete footer (shown only on small screens) -->
                        <div class="d-lg-none border-top p-2 d-flex gap-2 justify-content-end bg-body">
                            <button type="button" class="btn btn-sm btn-danger d-none" id="ct-delete-btn-mobile" onclick="deleteCustomTheme()">🗑️</button>
                            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal" onclick="cancelCustomTheme()">Cancel</button>
                            <button type="button" class="btn btn-sm btn-primary" onclick="saveCustomTheme()">💾 Save Theme</button>
                        </div>
                    </div><!-- end tab-theme -->

                    <!-- ══════════════════════════════════════════
                         TAB: 🎉 Celebration
                         ══════════════════════════════════════════ -->
                    <div class="tab-pane fade h-100 overflow-auto p-3" id="tab-celebration" role="tabpanel">
                        <!-- Enable / Disable toggles -->
                        <div class="d-flex gap-4 mb-3 flex-wrap">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="cel-enable-confetti" />
                                <label class="form-check-label fw-semibold" for="cel-enable-confetti">🎊 Confetti</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="cel-enable-fireworks" />
                                <label class="form-check-label fw-semibold" for="cel-enable-fireworks">🎆 Fireworks</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="cel-enable-balloons" />
                                <label class="form-check-label fw-semibold" for="cel-enable-balloons">🎈 Balloons</label>
                            </div>
                        </div>

                        <!-- Confetti -->
                        <h6 class="text-muted border-bottom pb-1 mb-2">🎊 Confetti</h6>
                        <div class="row g-2 mb-3">
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1" for="cel-confetti-type">Particle type</label>
                                <select id="cel-confetti-type" class="form-select form-select-sm" onchange="_updateEmojiVisibility(this.value==='emoji')">
                                    <option value="default">Default</option>
                                    <option value="stars">⭐ Stars</option>
                                    <option value="hearts">❤️ Hearts</option>
                                    <option value="snow">❄️ Snow</option>
                                    <option value="emoji">😀 Custom Emoji</option>
                                    <option value="christmasHoliday">🎄 Christmas</option>
                                    <option value="halloweenHoliday">🎃 Halloween</option>
                                    <option value="valentineHoliday">💕 Valentine's</option>
                                </select>
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1" for="cel-confetti-duration">Duration</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" id="cel-confetti-duration" class="form-control" min="1000" max="15000" step="500" value="4000" />
                                    <span class="input-group-text">ms</span>
                                </div>
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Particles: <span id="cel-particles-val">150</span></label>
                                <input type="range" id="cel-confetti-particles" class="form-range" min="20" max="500" step="10" value="150" oninput="document.getElementById('cel-particles-val').textContent=this.value" />
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Spread: <span id="cel-spread-val">70</span>°</label>
                                <input type="range" id="cel-confetti-spread" class="form-range" min="20" max="180" step="5" value="70" oninput="document.getElementById('cel-spread-val').textContent=this.value+'°'" />
                            </div>
                            <div class="col-md-4 col-6 d-flex align-items-center">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="cel-confetti-use-theme" onchange="_updateCustomColorsVisibility(!this.checked)" />
                                    <label class="form-check-label small" for="cel-confetti-use-theme">Use theme colors</label>
                                </div>
                            </div>
                            <div id="cel-custom-colors-group" class="col-12" style="display:none;">
                                <label class="form-label small mb-1" for="cel-confetti-colors">Custom colors (hex, comma-separated)</label>
                                <input type="text" id="cel-confetti-colors" class="form-control form-control-sm" placeholder="#ff0000,#00cc00,#0000ff,#ffcc00,#ff00ff" />
                            </div>
                            <div id="cel-emoji-group" class="col-12" style="display:none;">
                                <label class="form-label small mb-1" for="cel-confetti-emojis">Custom emojis (comma-separated)</label>
                                <input type="text" id="cel-confetti-emojis" class="form-control form-control-sm" placeholder="🎉,🎊,✨,🎈" />
                            </div>
                        </div>

                        <!-- Fireworks -->
                        <h6 class="text-muted border-bottom pb-1 mb-2">🎆 Fireworks</h6>
                        <div class="row g-2 mb-3">
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1" for="cel-fireworks-duration">Duration</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" id="cel-fireworks-duration" class="form-control" min="1000" max="30000" step="1000" value="5000" />
                                    <span class="input-group-text">ms</span>
                                </div>
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Intensity: <span id="cel-intensity-val">30</span></label>
                                <input type="range" id="cel-fireworks-intensity" class="form-range" min="5" max="100" step="5" value="30" oninput="document.getElementById('cel-intensity-val').textContent=this.value" />
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Particles: <span id="cel-fw-particles-val">50</span></label>
                                <input type="range" id="cel-fireworks-particles" class="form-range" min="10" max="200" step="10" value="50" oninput="document.getElementById('cel-fw-particles-val').textContent=this.value" />
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Explosion: <span id="cel-explosion-val">5</span></label>
                                <input type="range" id="cel-fireworks-explosion" class="form-range" min="1" max="20" step="1" value="5" oninput="document.getElementById('cel-explosion-val').textContent=this.value" />
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Launch: <span id="cel-rockets-val">50%</span></label>
                                <input type="range" id="cel-fireworks-rockets" class="form-range" min="0" max="100" step="5" value="50" oninput="document.getElementById('cel-rockets-val').textContent=this.value+'%'" />
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Hue range</label>
                                <div class="d-flex gap-1 align-items-center">
                                    <input type="number" id="cel-fireworks-hue-min" class="form-control form-control-sm" min="0" max="360" value="0" style="width:65px" />
                                    <span class="small">–</span>
                                    <input type="number" id="cel-fireworks-hue-max" class="form-control form-control-sm" min="0" max="360" value="360" style="width:65px" />
                                </div>
                            </div>
                        </div>

                        <!-- Balloons -->
                        <h6 class="text-muted border-bottom pb-1 mb-2">🎈 Balloons</h6>
                        <div class="row g-2 mb-3">
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1">Count: <span id="cel-balloon-count-val">10</span></label>
                                <input type="range" id="cel-balloon-count" class="form-range" min="1" max="30" step="1" value="10" oninput="document.getElementById('cel-balloon-count-val').textContent=this.value" />
                            </div>
                            <div class="col-md-4 col-6">
                                <label class="form-label small mb-1" for="cel-balloon-duration">Duration</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" id="cel-balloon-duration" class="form-control" min="2000" max="20000" step="1000" value="6000" />
                                    <span class="input-group-text">ms</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap border-top pt-3">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetCelebrationSettings()">↩ Reset defaults</button>
                            <button type="button" class="btn btn-sm btn-outline-success" onclick="testCelebration()">🎉 Test</button>
                            <button type="button" class="btn btn-sm btn-primary ms-auto" onclick="saveCelebrationSettingsFromForm()">💾 Save</button>
                        </div>
                    </div><!-- end tab-celebration -->

                    <!-- ══════════════════════════════════════════
                         TAB: 👤 Profile
                         ══════════════════════════════════════════ -->
                    <div class="tab-pane fade h-100 overflow-auto p-3" id="tab-profile" role="tabpanel">
                        <div class="row g-3" style="max-width:460px;">
                            <div class="col-12">
                                <label class="form-label fw-semibold" for="profile-display-name">Display Name</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="profile-display-name" placeholder="Your name" maxlength="50" />
                                    <button class="btn btn-primary" onclick="saveProfileName()">Save</button>
                                </div>
                                <div class="form-text">Changes your name in the current room immediately.</div>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="profile-observer-mode" onchange="onProfileObserverChange(this.checked)" />
                                    <label class="form-check-label fw-semibold" for="profile-observer-mode">Observer Mode</label>
                                </div>
                                <div class="form-text">Observers can see voting but cannot cast votes.</div>
                            </div>
                        </div>
                    </div><!-- end tab-profile -->

                    <!-- ══════════════════════════════════════════
                         TAB: ℹ️ About
                         ══════════════════════════════════════════ -->
                    <div class="tab-pane fade h-100 overflow-auto p-3" id="tab-about" role="tabpanel">

                        <!-- Keyboard shortcuts -->
                        <h6 class="fw-bold mb-2">⌨️ Keyboard Shortcuts</h6>
                        <table class="table table-sm table-borderless mb-4" style="max-width:360px;">
                            <tbody>
                                <tr><td><kbd>Space</kbd></td><td>Reveal votes</td></tr>
                                <tr><td><kbd>R</kbd></td><td>Reset votes</td></tr>
                                <tr><td><kbd>1</kbd>–<kbd>9</kbd></td><td>Select vote card by position</td></tr>
                                <tr><td><kbd>Esc</kbd></td><td>Unselect vote / close modal</td></tr>
                            </tbody>
                        </table>

                        <!-- Recent changes -->
                        <h6 class="fw-bold mb-2">📋 What's New</h6>
                        <p class="mb-2"><strong>4/27/2026</strong></p>
                        <ul class="mb-2">
                            <li>Unified ⚙️ Settings modal — Theme, Celebration, Profile, and About all in one place.</li>
                            <li>Custom theme editor always available — customize from any theme, not just custom ones.</li>
                            <li>Vote history shown after each round (below participants).</li>
                            <li>Story import: paste a list of stories to add them all at once.</li>
                            <li>Skip vote (🚫) card option added to room controls.</li>
                            <li>Profile tab: change your name and observer mode directly from Settings.</li>
                            <li>Keyboard shortcut: number keys 1–9 to quickly select a vote card.</li>
                        </ul>
                        <p class="mb-2"><strong>4/27/2026</strong></p>
                        <ul class="mb-2">
                            <li>Unselecting your vote now resets it for you (no more stuck votes).</li>
                            <li>Participant badges now show correctly cleared/voted state for all users including yourself.</li>
                            <li>Confirmation dialogs added for estimate set changes and vote resets.</li>
                            <li>Participant badge border width and voted color now fully respond to the custom theme settings.</li>
                            <li>Custom theme editor completely redesigned — grouped sections, collapsible, with a live side preview.</li>
                            <li>Theme editor now exposes <strong>all</strong> color and style variables.</li>
                        </ul>
                        <p class="mb-2"><strong>3/4/2026</strong></p>
                        <ul class="mb-2">
                            <li>🎉 Consensus now triggers a full celebration — confetti, fireworks, and balloons!</li>
                            <li>All celebration effects are independently toggleable and fully configurable.</li>
                            <li>Confetti supports theme-matched colors, holiday modes, emoji, stars, snow, and custom colors.</li>
                            <li>Custom themes can now specify their own confetti colors in the theme builder.</li>
                            <li>Fixed a too-many-redirects issue for users on shared hosting.</li>
                        </ul>
                        <p class="mb-2"><strong>3/4/2026</strong></p>
                        <ul class="mb-0">
                            <li>Creating a new custom theme now starts with your current theme automatically.</li>
                            <li>You can now create, edit, save, import, and export custom themes.</li>
                            <li>Share room invite links more easily.</li>
                            <li>People joining from a link are guided to enter their name first.</li>
                            <li>Added a quick Recent Changes button in the top bar.</li>
                        </ul>
                    </div><!-- end tab-about -->

                </div><!-- end tab-content -->
            </div>
        </div>
    </div><!-- end settingsModal -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Celebration libraries (canvas-confetti + fireworks-js) loaded from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1/dist/confetti.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fireworks-js@2/dist/index.umd.js"></script>
    <script src="~/js/celebration.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Register service worker for PWA
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(err => console.warn('SW registration failed:', err));
        }
    </script>
</body>
</html>


