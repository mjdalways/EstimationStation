@{
    ViewData["Title"] = "Lobby";
    var inviteRoom = ViewData["InviteRoom"] as string;
}

<div class="lobby-container">
    <div class="lobby-card">
        <div class="lobby-header">
            <h1 class="lobby-title">🃏 EstimationStation</h1>
            <p class="lobby-subtitle">Collaborative Planning Poker for your team</p>
            @if (!string.IsNullOrWhiteSpace(inviteRoom))
            {
                <div class="alert alert-info py-2 mt-2 mb-0" role="alert">
                    🔗 You've been invited to join room <strong>@inviteRoom</strong>. Enter your name to continue.
                </div>
            }
        </div>

        <div class="lobby-body">
            <!-- Player Name -->
            <div class="form-section">
                <label class="form-label" for="playerName">Your Name</label>
                <input type="text" id="playerName" class="form-control form-control-lg" placeholder="Enter your name..." maxlength="50" />
            </div>

            <!-- Create / Join Tabs -->
            <div class="room-tabs-section">
                <ul class="nav nav-tabs room-nav-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="create-tab" data-bs-toggle="tab" data-bs-target="#createPanel" type="button" role="tab">
                            ✨ Create Room
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="join-tab" data-bs-toggle="tab" data-bs-target="#joinPanel" type="button" role="tab">
                            🚪 Join Room
                        </button>
                    </li>
                </ul>
                <div class="tab-content room-tab-content">
                    <div class="tab-pane fade show active" id="createPanel" role="tabpanel">
                        <input type="text" id="createRoomName" class="form-control mb-3" placeholder="Room name..." maxlength="50" />
                        <button class="btn btn-primary w-100" id="createBtn" onclick="createRoom()">
                            ✨ Create Room
                        </button>
                    </div>
                    <div class="tab-pane fade" id="joinPanel" role="tabpanel">
                        <input type="text" id="joinRoomName" class="form-control mb-3" placeholder="Room name..." maxlength="50" />
                        <button class="btn btn-secondary w-100" id="joinBtn" onclick="joinRoom()">
                            🚪 Join Room
                        </button>
                    </div>
                </div>
            </div>

            <!-- Recent Rooms -->
            <div id="recentRoomsSection" class="mt-3" style="display:none;">
                <label class="form-label">Recent Rooms</label>
                <div id="recentRoomsList" class="recent-rooms-list"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const inviteRoom = @Json.Serialize(inviteRoom ?? "");

    function createRoom() {
        const name = document.getElementById('playerName').value.trim();
        const room = document.getElementById('createRoomName').value.trim();
        if (!name) { alert('Please enter your name.'); return; }
        if (!room) { alert('Please enter a room name.'); return; }
        saveToLocalStorage(name, room);
        window.location.href = `/room/${encodeURIComponent(room)}?name=${encodeURIComponent(name)}`;
    }

    function joinRoom() {
        const name = document.getElementById('playerName').value.trim();
        const room = document.getElementById('joinRoomName').value.trim();
        if (!name) { alert('Please enter your name.'); return; }
        if (!room) { alert('Please enter a room name.'); return; }
        saveToLocalStorage(name, room);
        window.location.href = `/room/${encodeURIComponent(room)}?name=${encodeURIComponent(name)}`;
    }

    function saveToLocalStorage(name, room) {
        localStorage.setItem('es_playerName', name);
        let rooms = JSON.parse(localStorage.getItem('es_recentRooms') || '[]');
        rooms = rooms.filter(r => r !== room);
        rooms.unshift(room);
        rooms = rooms.slice(0, 5);
        localStorage.setItem('es_recentRooms', JSON.stringify(rooms));
    }

    function loadRecentRooms() {
        const rooms = JSON.parse(localStorage.getItem('es_recentRooms') || '[]');
        if (rooms.length === 0) return;
        const section = document.getElementById('recentRoomsSection');
        const list = document.getElementById('recentRoomsList');
        section.style.display = 'block';
        list.innerHTML = rooms.map(r => `
            <button class="recent-room-btn" onclick="quickJoin('${r.replace(/'/g, "\\'")}')">
                🏠 ${r}
            </button>
        `).join('');
    }

    function quickJoin(room) {
        const name = document.getElementById('playerName').value.trim();
        if (!name) { alert('Please enter your name first.'); return; }
        saveToLocalStorage(name, room);
        window.location.href = `/room/${encodeURIComponent(room)}?name=${encodeURIComponent(name)}`;
    }

    // Keyboard shortcuts
    document.getElementById('createRoomName').addEventListener('keypress', e => { if (e.key === 'Enter') createRoom(); });
    document.getElementById('joinRoomName').addEventListener('keypress', e => { if (e.key === 'Enter') joinRoom(); });

    // Load on page start
    const savedName = localStorage.getItem('es_playerName');
    if (savedName) document.getElementById('playerName').value = savedName;

    if (inviteRoom) {
        document.getElementById('joinRoomName').value = inviteRoom;
        const joinTab = document.getElementById('join-tab');
        if (joinTab && typeof bootstrap !== 'undefined') {
            bootstrap.Tab.getOrCreateInstance(joinTab).show();
        }
        document.getElementById('playerName').focus();
    }

    loadRecentRooms();
</script>
}
