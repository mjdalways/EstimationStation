@model EstimationStation.Models.RoomViewModel
@{
    ViewData["Title"] = Model.RoomName;
}

@section NavbarExtra {
<div class="d-flex align-items-center gap-2 flex-wrap">
    <span class="navbar-text" id="navRoomName">🏠 @Model.RoomName</span>
    <span class="navbar-text" id="navPlayerName">👤 <span id="displayName">@Model.PlayerName</span></span>
    <button class="btn btn-sm btn-outline-info" onclick="copyInviteLink()" title="Copy room invite link">🔗 Invite</button>
    <button class="btn btn-sm btn-outline-light" onclick="promptRename()">✏️</button>
    <button class="btn btn-sm btn-outline-warning" onclick="leaveRoom()">🚪 Leave</button>
</div>
}

<div class="room-layout" id="roomLayout">
    <!-- Left Panel: Stories -->
    <div class="stories-panel" id="storiesPanel">
        <div class="panel-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0">📋 Stories</h6>
            <button class="btn btn-sm btn-primary" onclick="toggleStoriesPanel()">◀</button>
        </div>
        <div class="add-story-form">
            <input type="text" id="newStoryInput" class="form-control form-control-sm" placeholder="Add story..." maxlength="200" />
            <button class="btn btn-sm btn-primary w-100 mt-1" onclick="addStory()">+ Add Story</button>
            <details class="mt-2">
                <summary class="small text-muted" style="cursor:pointer;">📋 Import multiple stories…</summary>
                <textarea id="importStoriesInput" class="form-control form-control-sm mt-1" rows="4"
                          placeholder="Paste one story per line..."></textarea>
                <button class="btn btn-sm btn-outline-primary w-100 mt-1" onclick="importStories()">Import All</button>
            </details>
        </div>
        <div id="storiesList" class="stories-list"></div>
    </div>

    <!-- Stories collapsed toggle -->
    <button class="stories-toggle-btn" id="storiesToggleBtn" onclick="toggleStoriesPanel()" style="display:none;" title="Show Stories">▶</button>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Current Story Bar -->
        <div class="current-story-bar">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="story-label">Current Story:</span>
                <span id="currentStoryDisplay" class="current-story-title">No story selected</span>
                <div id="timerDisplay" class="timer-display" style="display:none;">
                    <span id="timerIcon">⏱️</span> <span id="timerValue">0</span>s
                </div>
            </div>
        </div>

        <!-- Stats Bar (shown when votes revealed) -->
        <div id="statsBar" class="stats-bar" style="display:none;">
            <div class="stat-item">
                <span class="stat-label">Average</span>
                <span class="stat-value" id="statAverage">-</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">Min</span>
                <span class="stat-value" id="statMin">-</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">Max</span>
                <span class="stat-value" id="statMax">-</span>
            </div>
            <div id="consensusBadge" class="consensus-badge" style="display:none;">
                🎉 Consensus!
            </div>
        </div>

        <!-- Voting Cards -->
        <div class="voting-section">
            <h6 class="section-label">Your Vote</h6>
            <div id="cardContainer" class="card-container"></div>
        </div>

        <!-- Participants -->
        <div class="participants-section">
            <h6 class="section-label">Participants</h6>
            <div id="participantsContainer" class="participants-container"></div>
        </div>

        <!-- Vote History (populated by JS after each reveal) -->
        <div class="vote-history-section" id="voteHistorySection" style="display:none;">
            <button class="vote-history-toggle" onclick="toggleVoteHistory()">
                📜 Vote History <span id="voteHistoryChevron">▾</span>
            </button>
            <div id="voteHistoryList" class="vote-history-list" style="display:none;"></div>
        </div>
    </div>

    <!-- Right Controls Panel -->
    <div class="controls-panel">
        <div class="control-group">
            <h6 class="control-title">🎮 Controls</h6>
            <button class="btn btn-success w-100 mb-2" id="revealBtn" onclick="revealVotes()">👁️ Reveal</button>
            <button class="btn btn-secondary w-100 mb-2" id="hideBtn" onclick="hideVotes()" style="display:none;">🙈 Hide</button>
            <button class="btn btn-warning w-100 mb-2" onclick="resetVotes()">🔄 Reset</button>
        </div>

        <div class="control-group">
            <h6 class="control-title">⚙️ Settings</h6>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="autoRevealCheck" onchange="toggleAutoReveal(this.checked)" />
                <label class="form-check-label" for="autoRevealCheck">Auto-reveal</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="observerCheck" onchange="toggleObserver(this.checked)" />
                <label class="form-check-label" for="observerCheck">Observer mode</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="skipVoteCheck" onchange="toggleSkipVoteCard(this.checked)" />
                <label class="form-check-label" for="skipVoteCheck">🚫 Skip card</label>
            </div>
        </div>

        <div class="control-group">
            <h6 class="control-title">🎯 Estimate Set</h6>
            <select id="estimateSetSelect" class="form-select form-select-sm mb-2" onchange="changeEstimateSet(this.value)">
                <option value="fibonacci">Fibonacci</option>
                <option value="modified-fibonacci">Modified Fibonacci</option>
                <option value="t-shirt">T-Shirt</option>
                <option value="powers-of-2">Powers of 2</option>
                <option value="custom">Custom</option>
            </select>
            <div id="customEstimatesDiv" style="display:none;">
                <input type="text" id="customEstimatesInput" class="form-control form-control-sm mb-1" placeholder="1,2,3,5,8..." />
                <button class="btn btn-sm btn-primary w-100" onclick="applyCustomEstimates()">Apply</button>
            </div>
        </div>

        <div class="control-group">
            <h6 class="control-title">⏱️ Timer</h6>
            <div class="d-flex gap-1 flex-wrap mb-2">
                <button class="btn btn-sm btn-outline-primary" onclick="startTimer(30)">30s</button>
                <button class="btn btn-sm btn-outline-primary" onclick="startTimer(60)">1m</button>
                <button class="btn btn-sm btn-outline-primary" onclick="startTimer(90)">90s</button>
                <button class="btn btn-sm btn-outline-primary" onclick="startTimer(180)">3m</button>
                <button class="btn btn-sm btn-outline-primary" onclick="startTimer(300)">5m</button>
            </div>
            <button class="btn btn-sm btn-outline-danger w-100" onclick="stopTimer()">⏹️ Stop Timer</button>
        </div>

        <div class="control-group">
            <button class="btn btn-sm btn-outline-secondary w-100" onclick="exportCSV()">📥 Export CSV</button>
        </div>
    </div>
</div>

<!-- Chat Panel (collapsible bottom) -->
<div class="chat-panel" id="chatPanel">
    <div class="chat-header" onclick="toggleChat()">
        💬 Chat <span id="chatToggleIcon">▼</span>
    </div>
    <div class="chat-body" id="chatBody" style="display:none;">
        <div id="chatMessages" class="chat-messages"></div>
        <div class="chat-input-row">
            <input type="text" id="chatInput" class="form-control form-control-sm" placeholder="Type a message..." maxlength="500" />
            <button class="btn btn-sm btn-primary" onclick="sendChat()">Send</button>
        </div>
    </div>
</div>

<!-- Mobile Bottom Navigation Bar -->
<nav class="mobile-bottom-nav d-lg-none" id="mobileBottomNav">
    <button class="mobile-nav-btn" onclick="toggleMobilePanel('stories')" id="mobileStoriesBtn">
        <span class="mobile-nav-icon">📋</span>
        <span class="mobile-nav-label">Stories</span>
    </button>
    <button class="mobile-nav-btn mobile-nav-vote" onclick="scrollToCards()">
        <span class="mobile-nav-icon">🃏</span>
        <span class="mobile-nav-label">Vote</span>
    </button>
    <button class="mobile-nav-btn" onclick="toggleChat()" id="mobileChatBtn">
        <span class="mobile-nav-icon">💬</span>
        <span class="mobile-nav-label">Chat</span>
    </button>
    <button class="mobile-nav-btn" onclick="toggleMobilePanel('controls')" id="mobileControlsBtn">
        <span class="mobile-nav-icon">⚙️</span>
        <span class="mobile-nav-label">Controls</span>
    </button>
</nav>

@section Scripts {
<script>
    const ROOM_CONFIG = {
        roomName: @Json.Serialize(Model.RoomName),
        playerName: @Json.Serialize(Model.PlayerName)
    };

    // Mobile panel toggling
    function toggleMobilePanel(panel) {
        const panels = {
            stories: { el: document.getElementById('storiesPanel'), btn: document.getElementById('mobileStoriesBtn') },
            controls: { el: document.querySelector('.controls-panel'), btn: document.getElementById('mobileControlsBtn') }
        };
        const target = panels[panel];
        const isVisible = target.el.classList.contains('mobile-visible');

        // Close all panels first
        Object.values(panels).forEach(p => { p.el.classList.remove('mobile-visible'); p.btn.classList.remove('active'); });

        // Toggle the requested one
        if (!isVisible) {
            target.el.classList.add('mobile-visible');
            target.btn.classList.add('active');
        }
    }

    function scrollToCards() {
        document.getElementById('cardContainer').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    async function copyInviteLink() {
        const inviteUrl = `${window.location.origin}/room/${encodeURIComponent(ROOM_CONFIG.roomName)}`;
        try {
            await navigator.clipboard.writeText(inviteUrl);
            alert('Invite link copied. Share it and users will be asked for their name before joining.');
        } catch {
            prompt('Copy this invite link:', inviteUrl);
        }
    }
</script>
<script src="~/js/room.js" asp-append-version="true"></script>
}
